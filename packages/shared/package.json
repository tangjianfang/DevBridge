{
  "name": "@devbridge/shared",
  "version": "1.0.0",
  "private": true,
  "description": "Shared TypeScript types and utilities for DevBridge",
  "main":  "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types":  "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build":      "tsc -p tsconfig.json",
    "build:watch":"tsc -p tsconfig.json --watch",
    "clean":      "rimraf dist",
    "typecheck":  "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "rimraf":      "^6.0.1",
    "typescript":  "^5.6.3"
  }
}
