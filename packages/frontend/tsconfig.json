{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target":    "ES2022",
    "lib":       ["ES2022", "DOM", "DOM.Iterable"],
    "module":    "ESNext",
    "moduleResolution": "bundler",
    "jsx":       "react-jsx",
    "outDir":    "dist",
    "noEmit":    true,
    "paths": {
      "@devbridge/shared": ["../shared/src"]
    }
  },
  "include": ["src/**/*", "../shared/src/**/*"],
  "exclude": ["dist", "node_modules"]
}
