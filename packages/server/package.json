{
  "name": "@devbridge/server",
  "version": "1.0.0",
  "private": true,
  "description": "DevBridge backend — Node.js hardware gateway service",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types":  "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build":      "tsc -p tsconfig.json",
    "build:watch":"tsc -p tsconfig.json --watch",
    "dev":        "tsx watch src/index.ts",
    "start":      "node dist/index.js",
    "clean":      "rimraf dist",
    "typecheck":  "tsc --noEmit"
  },
  "dependencies": {
    "@devbridge/shared":     "workspace:*",
    "@fastify/cors":         "^9.0.1",
    "@fastify/rate-limit":   "^9.1.0",
    "@fastify/websocket":    "^10.0.1",
    "chokidar":              "^3.6.0",
    "esbuild":               "^0.24.0",
    "fastify":               "^4.28.1",
    "pino":                  "^9.5.0",
    "pino-pretty":           "^12.1.0"
  },
  "devDependencies": {
    "@types/node":       "^20.17.0",
    "rimraf":            "^6.0.1",
    "tsx":               "^4.19.2",
    "typescript":        "^5.6.3"
  },
  "optionalDependencies": {
    "node-hid":              "^3.1.1",
    "serialport":            "^12.0.0",
    "@abandonware/noble":    "^1.9.2-15",
    "usb":                   "^2.14.0",
    "node-ffi-napi":         "^4.0.3",
    "ref-napi":              "^3.0.3"
  }
}
